generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  /// Pooled connection (e.g. Supabase pooler :6543) for app runtime.
  url       = env("DATABASE_URL")
  /// Direct Postgres (e.g. db.<project>.supabase.co :5432) for Prisma CLI (migrate, db pull, introspect).
  directUrl = env("DIRECT_DATABASE_URL")
}

model audit_logs {
  id              String         @id @default(uuid()) @db.Uuid
  organization_id String?        @db.Uuid
  user_id         String?        @db.VarChar(255)
  entity_type     String         @db.VarChar(100)
  entity_id       String         @db.Uuid
  action          String         @db.VarChar(50)
  event_type      String?        @db.VarChar(128)
  severity        String?        @db.VarChar(32)
  correlation_id  String?        @db.VarChar(255)
  old_values      Json?
  new_values      Json?
  metadata        Json?
  ip_address      String?        @db.VarChar(45)
  user_agent      String?
  created_at      DateTime       @default(now()) @db.Timestamptz(6)
  organizations   organizations? @relation(fields: [organization_id], references: [id])

  @@index([created_at(sort: Desc)])
  @@index([entity_type, entity_id])
  @@index([organization_id])
  @@index([user_id])
  @@index([event_type, created_at(sort: Desc)])
  @@index([correlation_id])
}

enum WebhookProvider {
  STRIPE
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  DUPLICATE
  IGNORED
  ERROR
}

model webhook_events {
  id                       String              @id @default(uuid()) @db.Uuid
  provider                 WebhookProvider
  provider_event_id        String              @db.VarChar(255)
  event_type               String              @db.VarChar(128)
  livemode                 Boolean             @default(false)
  api_version              String?             @db.VarChar(32)
  request_id               String?             @db.VarChar(255)
  signature_present        Boolean             @default(false)
  signature_header         String?             @db.VarChar(512)
  received_at              DateTime            @default(now()) @db.Timestamptz(6)
  processed_at             DateTime?          @db.Timestamptz(6)
  status                   WebhookEventStatus  @default(RECEIVED)
  attempt_count            Int                 @default(0)
  last_error               String?             @db.Text
  last_error_at            DateTime?          @db.Timestamptz(6)
  duration_ms              Int?
  raw_body                 String              @db.Text
  headers                  Json?
  parsed_event             Json?
  correlation_id           String?             @db.VarChar(255)
  organization_id          String?             @db.Uuid
  payment_link_id          String?             @db.Uuid
  stripe_payment_intent_id String?             @db.VarChar(255)
  stripe_charge_id         String?             @db.VarChar(255)
  stripe_refund_id         String?             @db.VarChar(255)

  @@unique([provider, provider_event_id], name: "ux_webhook_events_provider_event_id")
  @@index([provider, status, received_at(sort: Desc)])
  @@index([payment_link_id, received_at(sort: Desc)])
  @@index([organization_id, received_at(sort: Desc)])
  @@index([stripe_payment_intent_id])
  @@index([stripe_refund_id])
}

/// Lightweight distributed lease rows for singleton cron/worker execution.
model operational_job_leases {
  job_name         String   @id @db.VarChar(128)
  owner_id         String   @db.VarChar(191)
  lease_expires_at DateTime @db.Timestamptz(6)
  acquired_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @updatedAt @db.Timestamptz(6)

  @@index([lease_expires_at], map: "operational_job_leases_lease_expires_at_idx")
}

model fx_snapshots {
  id              String         @id @default(uuid()) @db.Uuid
  payment_link_id String         @db.Uuid
  snapshot_type   FxSnapshotType
  token_type      PaymentToken?
  base_currency   String         @db.VarChar(10)
  quote_currency  String         @db.VarChar(10)
  rate            Decimal        @db.Decimal(18, 8)
  provider        String         @db.VarChar(100)
  captured_at     DateTime       @default(now()) @db.Timestamptz(6)
  payment_links   payment_links  @relation(fields: [payment_link_id], references: [id], onDelete: Cascade)

  @@unique([payment_link_id, snapshot_type, base_currency, quote_currency], name: "ux_fx_snapshots_link_type_pair")
}

model ledger_accounts {
  id              String            @id @default(uuid()) @db.Uuid
  organization_id String            @db.Uuid
  code            String            @db.VarChar(50)
  name            String            @db.VarChar(255)
  account_type    LedgerAccountType
  xero_account_id String?           @db.VarChar(255)
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  organizations   organizations     @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  ledger_entries  ledger_entries[]

  @@unique([organization_id, code])
}

model ledger_entries {
  id                String          @id @default(uuid()) @db.Uuid
  payment_link_id   String          @db.Uuid
  ledger_account_id String          @db.Uuid
  entry_type        LedgerEntryType
  amount            Decimal         @db.Decimal(18, 8)
  currency          String          @db.Char(3)
  description       String
  idempotency_key   String          @unique @db.VarChar(255)
  created_at        DateTime        @default(now()) @db.Timestamptz(6)
  ledger_accounts   ledger_accounts @relation(fields: [ledger_account_id], references: [id])
  payment_links     payment_links   @relation(fields: [payment_link_id], references: [id], onDelete: Cascade)
}

model merchant_settings {
  id                String  @id @default(uuid()) @db.Uuid
  organization_id   String  @db.Uuid
  display_name      String  @db.VarChar(255)
  default_currency  String  @db.Char(3)
  stripe_account_id String? @db.VarChar(255)
  hedera_account_id String? @db.VarChar(50)

  // Sprint 26: Invoice UX Improvements
  organization_logo_url String? @db.VarChar(1024)

  // Xero Account Mappings
  xero_revenue_account_id         String? @db.VarChar(255)
  xero_receivable_account_id      String? @db.VarChar(255)
  xero_stripe_clearing_account_id String? @db.VarChar(255)
  xero_hbar_clearing_account_id   String? @db.VarChar(255)
  xero_usdc_clearing_account_id   String? @db.VarChar(255)
  xero_usdt_clearing_account_id   String? @db.VarChar(255)
  xero_audd_clearing_account_id   String? @db.VarChar(255)
  xero_wise_clearing_account_id   String? @db.VarChar(255)
  xero_fee_expense_account_id     String? @db.VarChar(255)

  // Wise (payment links): profile id for API; null = Wise not enabled
  wise_profile_id String? @db.VarChar(255)
  wise_enabled    Boolean @default(false)
  wise_currency   String? @db.Char(3) // default currency for Wise payouts, falls back to default_currency

  // Sprint 25: Multi-Currency Enhancement
  enabled_currencies            String[] @default(["USD", "AUD"])
  show_symbols_in_ui            Boolean  @default(true)
  show_codes_in_ui              Boolean  @default(false)
  auto_refresh_rates            Boolean  @default(true)
  rate_refresh_interval_minutes Int      @default(5)

  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  updated_at    DateTime      @updatedAt @db.Timestamptz(6)
  organizations organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
}

model organizations {
  id                           String                         @id @default(uuid()) @db.Uuid
  clerk_org_id                 String                         @unique @db.VarChar(255)
  name                         String                         @db.VarChar(255)
  /// Provvypay SaaS plan — updated by Stripe webhooks for Professional/Growth.
  subscription_plan              String                         @default("starter") @db.VarChar(32)
  /// inactive | active | trialing | past_due | canceled (Stripe-aligned for paid plans).
  subscription_status            String                         @default("inactive") @db.VarChar(32)
  /// Stripe Billing customer for workspace SaaS subscription.
  stripe_customer_id             String?                        @unique @db.VarChar(255)
  /// Active Stripe subscription id (source of truth for paid entitlements).
  stripe_subscription_id         String?                        @unique @db.VarChar(255)
  current_period_end             DateTime?                      @db.Timestamptz(6)
  created_at                   DateTime                       @default(now()) @db.Timestamptz(6)
  audit_logs                   audit_logs[]
  ledger_accounts              ledger_accounts[]
  merchant_settings            merchant_settings[]
  payment_links                payment_links[]
  payment_events               payment_events[]
  referral_links               referral_links[]
  xero_connections             xero_connections?
  notifications                notifications[]
  notification_preferences     notification_preferences[]
  // Sprint 25: Multi-Currency Enhancement
  currency_configs             currency_configs[]
  fx_rate_overrides            fx_rate_overrides[]
  currency_display_preferences currency_display_preferences[]
  user_organizations           user_organizations[]
  // Manual payouts (Option B)
  payout_methods               payout_methods[]
  payout_batches               payout_batches[]
  recurring_templates          recurring_templates[]
  organization_services        organization_services[]
  referral_codes               referral_codes[]
  operational_onboarding_transitions operational_onboarding_transitions[]
}

/// Immutable operational onboarding / bootstrap / graph initialization transitions.
model operational_onboarding_transitions {
  id                     String         @id @default(uuid()) @db.Uuid
  organization_id        String?        @db.Uuid
  project_id             String?        @db.VarChar(128)
  record_kind            String         @default("transition") @db.VarChar(64)
  phase                  String         @db.VarChar(64)
  previous_phase         String?        @db.VarChar(64)
  status                 String         @db.VarChar(32)
  started_at             DateTime       @default(now()) @db.Timestamptz(6)
  completed_at           DateTime?      @db.Timestamptz(6)
  failed_at              DateTime?      @db.Timestamptz(6)
  correlation_id         String         @db.VarChar(255)
  trigger_source         String         @db.VarChar(128)
  user_id                String?        @db.VarChar(255)
  metadata               Json?
  orchestration_event_id String?        @db.VarChar(255)
  organizations          organizations? @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([organization_id, started_at(sort: Desc)])
  @@index([correlation_id])
  @@index([organization_id, phase, status])
  @@index([organization_id, correlation_id])
}

model user_organizations {
  id              String        @id @default(uuid()) @db.Uuid
  user_id         String        @db.VarChar(255)
  organization_id String        @db.Uuid
  role            String        @default("MEMBER") @db.VarChar(50)
  created_at      DateTime      @default(now()) @db.Timestamptz(6)
  updated_at      DateTime      @default(now()) @db.Timestamptz(6)
  organizations   organizations @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@unique([user_id, organization_id])
  @@index([user_id])
  @@index([organization_id])
  @@index([role])
}

/// Merchant-defined schedule that creates a new OPEN payment link (invoice) each run.
model recurring_templates {
  id                     String                    @id @default(uuid()) @db.Uuid
  organization_id      String                    @db.Uuid
  amount                 Decimal                   @db.Decimal(18, 2)
  currency               String                    @db.Char(3)
  description            String                    @db.Text
  customer_email         String?                   @db.VarChar(255)
  recurrence_interval    RecurringTemplateInterval
  interval_count         Int                       @default(1)
  next_run_at            DateTime                  @db.Timestamptz(6)
  end_date               DateTime?                 @db.Date
  status                 RecurringTemplateStatus   @default(ACTIVE)
  /// Calendar days after invoice_date for due_date; null = no due date on generated links.
  due_days_after_invoice Int?
  last_run_at            DateTime?                 @db.Timestamptz(6)
  created_at             DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at             DateTime                  @updatedAt @db.Timestamptz(6)
  organizations          organizations             @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@index([status, next_run_at])
  @@index([organization_id])
}

model payment_events {
  id                       String                    @id @default(uuid()) @db.Uuid
  /// Nullable for manual / CSV-import rows that are not tied to a Payment Link row.
  payment_link_id          String?                   @db.Uuid
  organization_id          String?                   @db.Uuid
  /// Deal Network pilot deal id when this event is explicitly linked to a pilot deal.
  pilot_deal_id            String?                   @db.VarChar(255)
  event_type               PaymentEventType
  payment_method           PaymentMethod?
  /// How this row entered the system (orthogonal to `payment_method` rail).
  source_type              PaymentEventSourceType?
  source_reference         String?                   @db.VarChar(512)
  gross_amount             Decimal?                  @db.Decimal(18, 8)
  net_amount               Decimal?                  @db.Decimal(18, 8)
  currency_received        String?                   @db.VarChar(10)
  received_at              DateTime?                 @db.Timestamptz(6)
  record_status            PaymentEventRecordStatus?
  raw_payload_json         Json?
  stripe_payment_intent_id String?                   @db.VarChar(255)
  stripe_event_id          String?                   @db.VarChar(255)
  hedera_transaction_id    String?                   @db.VarChar(255)
  wise_transfer_id         String?                   @db.VarChar(255)
  amount_received          Decimal?                  @db.Decimal(18, 8)
  correlation_id           String?                   @db.VarChar(255)
  metadata                 Json?
  created_at               DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at               DateTime                  @updatedAt @db.Timestamptz(6)
  payment_links            payment_links?            @relation(fields: [payment_link_id], references: [id], onDelete: Cascade)
  organizations            organizations?            @relation(fields: [organization_id], references: [id], onDelete: SetNull)
  pilot_deal               deal_network_pilot_deals? @relation("PilotDealPaymentEvents", fields: [pilot_deal_id], references: [id], onDelete: SetNull)
  deal_network_pilot_obligations deal_network_pilot_obligations[]

  @@index([payment_link_id, correlation_id], name: "payment_events_payment_link_correlation_idx")
  @@index([payment_link_id, created_at])
  @@index([stripe_event_id])
  @@index([wise_transfer_id])
  @@index([pilot_deal_id])
  @@index([organization_id])
  @@index([source_type])
}

model payment_links {
  id                String            @id @default(uuid()) @db.Uuid
  organization_id   String            @db.Uuid
  short_code        String            @unique @db.VarChar(8)
  status            PaymentLinkStatus @default(DRAFT)
  payment_method    PaymentMethod? // STRIPE | HEDERA | WISE | CRYPTO (null = legacy, all methods)
  amount            Decimal           @db.Decimal(18, 2)
  /// @deprecated Kept in sync with `invoice_currency` for backwards compatibility; prefer `invoice_currency` in new code.
  currency          String            @db.Char(3)
  /// ISO 4217 accounting currency for the invoice amount, public display, and Xero ACCREC — independent of payment rail (Stripe / HBAR / etc.).
  invoice_currency  String            @db.Char(3)
  description       String
  invoice_reference String?           @db.VarChar(255)
  /// Option B commission: links invoice to `referral_links` so Wise/Hedera (no Stripe metadata) can resolve revenue share.
  referral_link_id  String?           @db.Uuid
  /// Sprint 1: optional participant code row used for this invoice (audit / dashboards).
  referral_code_id  String?           @db.Uuid
  /// Denormalized public referral code string at invoice creation (immutable).
  attribution_referral_code        String?            @db.VarChar(50)
  /// Participant (Supabase user id) attributed at invoice creation.
  attributed_participant_user_id   String?            @db.VarChar(255)
  attribution_source               AttributionSource?
  /// Stripe-shaped commission fields frozen at invoice creation; settlement prefers this over DB rule lookup.
  commission_attribution_snapshot  Json?
  organization_service_id          String?            @db.Uuid
  customer_email    String?           @db.VarChar(255)
  customer_phone    String?           @db.VarChar(50)
  customer_name     String?           @db.VarChar(255)
  expires_at        DateTime?         @db.Timestamptz(6)

  // Sprint 26: Invoice UX Improvements
  /// Explicit invoice issue date (can be backdated); distinct from due_date and created_at.
  invoice_date         DateTime? @db.Timestamptz(6)
  due_date            DateTime? @db.Timestamptz(6)
  xero_invoice_number String?   @db.VarChar(255)

  // Sprint 25: Multi-Currency Enhancement
  customer_selected_currency  String?  @db.Char(3)
  conversion_rate_at_creation Decimal? @db.Decimal(18, 8)
  base_amount                 Decimal? @db.Decimal(18, 2)
  base_currency               String?  @db.Char(3)

  // Wise-specific (when payment_method = WISE)
  wise_quote_id          String?  @db.VarChar(255)
  wise_transfer_id       String?  @db.VarChar(255)
  wise_status            String?  @db.VarChar(50)
  wise_received_amount   Decimal? @db.Decimal(18, 8)
  wise_received_currency String?  @db.Char(3)

  /// Invoice-only: public page shows invoice details without online checkout UI
  invoice_only_mode Boolean @default(false)
  /// When payment_method = HEDERA: INTERACTIVE (wallet connect) vs MANUAL (copy wallet instructions)
  hedera_checkout_mode String? @db.VarChar(32)

  /// When payment_method = CRYPTO: manual wallet instructions (any chain)
  crypto_network       String? @db.VarChar(255)
  crypto_address       String? @db.VarChar(512)
  crypto_currency      String? @db.VarChar(64)
  crypto_memo          String? @db.VarChar(512)
  crypto_instructions  String? @db.Text

  /// When payment_method = MANUAL_BANK: operator-defined transfer instructions.
  manual_bank_recipient_name    String? @db.VarChar(255)
  manual_bank_currency          String? @db.VarChar(16)
  manual_bank_destination_type  String? @db.VarChar(64)
  manual_bank_bank_name         String? @db.VarChar(255)
  manual_bank_account_number    String? @db.VarChar(128)
  manual_bank_iban              String? @db.VarChar(128)
  manual_bank_swift_bic         String? @db.VarChar(64)
  manual_bank_routing_sort_code String? @db.VarChar(64)
  manual_bank_wise_reference    String? @db.VarChar(255)
  manual_bank_revolut_handle    String? @db.VarChar(255)
  manual_bank_instructions      String? @db.Text

  /// Merchant-uploaded payment instruction file (PNG/JPEG/PDF); binary in Supabase Storage, metadata here
  attachment_storage_key String? @db.VarChar(1024)
  attachment_bucket      String? @default("payment-link-attachments") @db.VarChar(128)
  attachment_filename    String? @db.VarChar(512)
  attachment_mime_type   String? @db.VarChar(128)
  attachment_size_bytes  Int?
  /// Invoice delivery metadata (manual send action)
  last_sent_at           DateTime? @db.Timestamptz(6)
  last_sent_to_email     String?   @db.VarChar(512)

  /// At most one chargeable Stripe Checkout session per link (coordinator reuses while open).
  active_stripe_checkout_session_id     String?   @db.VarChar(255)
  active_stripe_checkout_expires_at     DateTime? @db.Timestamptz(6)

  created_at              DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at              DateTime                  @db.Timestamptz(6)
  fx_snapshots            fx_snapshots[]
  ledger_entries          ledger_entries[]
  payment_events          payment_events[]
  organizations           organizations             @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  commission_referral_link referral_links?          @relation(fields: [referral_link_id], references: [id], onDelete: SetNull)
  referral_code_row      referral_codes?          @relation(fields: [referral_code_id], references: [id], onDelete: SetNull)
  organization_service   organization_services?   @relation(fields: [organization_service_id], references: [id], onDelete: SetNull)
  xero_syncs              xero_syncs[]
  multi_currency_invoices multi_currency_invoices[]
  commission_obligations  commission_obligations[]
  crypto_payment_confirmations crypto_payment_confirmations[]
  manual_bank_payment_confirmations manual_bank_payment_confirmations[]
  /// Deal Network pilot project (Strait) — optional invoice↔project coordination link.
  pilot_deal_id           String?                   @db.VarChar(255)
  pilot_deal              deal_network_pilot_deals? @relation("PilotDealPaymentLinks", fields: [pilot_deal_id], references: [id], onDelete: SetNull)

  @@index([organization_id, status])
  @@index([due_date])
  @@index([expires_at])
  @@index([payment_method])
  @@index([pilot_deal_id])
  @@index([referral_link_id])
  @@index([referral_code_id])
  @@index([organization_service_id])
}

model organization_services {
  id              String          @id @default(uuid()) @db.Uuid
  organization_id String          @db.Uuid
  name            String          @db.VarChar(255)
  description     String          @db.Text
  price           Decimal         @db.Decimal(18, 2)
  currency        String          @db.Char(3)
  active          Boolean         @default(true)
  created_at      DateTime        @default(now()) @db.Timestamptz(6)
  updated_at      DateTime        @updatedAt @db.Timestamptz(6)
  organizations   organizations   @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  payment_links   payment_links[]

  @@index([organization_id, active])
}

/// Participant-facing referral code (1:1 with commission-bearing `referral_links`).
model referral_codes {
  id                  String             @id @default(uuid()) @db.Uuid
  organization_id     String             @db.Uuid
  participant_user_id String?            @db.VarChar(255)
  referral_link_id    String             @unique @db.Uuid
  code                String             @unique @db.VarChar(50)
  slug                String?            @unique @db.VarChar(64)
  status              ReferralCodeStatus @default(ACTIVE)
  created_at          DateTime           @default(now()) @db.Timestamptz(6)
  expires_at          DateTime?          @db.Timestamptz(6)
  organizations       organizations      @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  referral_links      referral_links     @relation(fields: [referral_link_id], references: [id], onDelete: Cascade)
  payment_links       payment_links[]

  @@index([organization_id])
  @@index([participant_user_id])
  @@index([code])
}

/// Payer-submitted “I sent crypto” + assisted verification (Payment Links manual crypto)
model crypto_payment_confirmations {
  id                     String                         @id @default(uuid()) @db.Uuid
  payment_link_id        String                         @db.Uuid
  status                 CryptoPaymentConfirmationStatus @default(PENDING)
  payer_network          String                         @db.VarChar(255)
  payer_amount_sent      String                         @db.VarChar(64)
  payer_wallet_address   String                         @db.VarChar(512)
  payer_currency         String?                        @db.VarChar(64)
  payer_tx_hash          String?                        @db.VarChar(255)
  verification_status    CryptoVerificationStatus?
  match_confidence       MatchConfidence?
  verification_issues    Json                           @default("[]")
  merchant_acknowledged_at DateTime?                    @db.Timestamptz(6)
  merchant_investigation_flag Boolean                  @default(false)
  created_at             DateTime                       @default(now()) @db.Timestamptz(6)
  reviewed_at            DateTime?                      @db.Timestamptz(6)
  payment_links          payment_links                  @relation(fields: [payment_link_id], references: [id], onDelete: Cascade)

  @@index([payment_link_id, status])
  @@index([status, created_at])
}

/// Payer-submitted manual bank transfer notice (no merchant pre-approval gate).
model manual_bank_payment_confirmations {
  id                         String   @id @default(uuid()) @db.Uuid
  payment_link_id            String   @db.Uuid
  status                     CryptoPaymentConfirmationStatus @default(PENDING)
  payer_amount_sent          String   @db.VarChar(64)
  payer_currency             String?  @db.VarChar(16)
  payer_destination          String?  @db.VarChar(255)
  payer_payment_method_used  String?  @db.VarChar(128)
  payer_reference            String?  @db.VarChar(255)
  payer_proof_details        String?  @db.Text
  payer_note                 String?  @db.Text
  verification_status        CryptoVerificationStatus?
  match_confidence           MatchConfidence?
  verification_issues        Json     @default("[]")
  merchant_acknowledged_at   DateTime? @db.Timestamptz(6)
  merchant_investigation_flag Boolean @default(false)
  created_at                 DateTime @default(now()) @db.Timestamptz(6)
  reviewed_at                DateTime? @db.Timestamptz(6)
  payment_links              payment_links @relation(fields: [payment_link_id], references: [id], onDelete: Cascade)

  @@index([payment_link_id, status])
  @@index([status, created_at])
}

model xero_connections {
  id              String        @id @default(uuid()) @db.Uuid
  organization_id String        @unique @db.Uuid
